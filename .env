# ============================================================================
# Judilibre Configuration (API Cour de cassation - GRATUITE)
# ============================================================================
JUDILIBRE_API_URL=https://api.judilibre.fr
JUDILIBRE_API_KEY=votre_cle_api_ici  # À obtenir sur https://developer.judilibre.fr
JUDILIBRE_TIMEOUT=30
JUDILIBRE_MAX_RETRIES=3
JUDILIBRE_CACHE_TTL=86400
JUDILIBRE_RATE_LIMIT=10

# Optionnel: Redis pour cache partagé
# REDIS_URL=redis://localhost:6379
# ============================================================================
# STREAMLIT CONFIGURATION
# ============================================================================
STREAMLIT_THEME=dark
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# ============================================================================
# COMPLIANCE ASSISTANT
# ============================================================================
COMPLIANCE_VECTOR_DB=./chroma_db
COMPLIANCE_METADATA_DIR=./metadata
COMPLIANCE_CACHE_DIR=./cache
COMPLIANCE_LLM_MODEL=google/flan-t5-large

# ============================================================================
# JUDILIBRE (optionnel - API gratuite)
# ============================================================================
JUDILIBRE_API_URL=https://api.judilibre.fr
JUDILIBRE_API_KEY=